            <Style>
              <Border><Style>None</Style></Border>
              <PaddingLeft>2pt</PaddingLeft>
              <PaddingRight>2pt</PaddingRight>
              <PaddingTop>2pt</PaddingTop>
              <PaddingBottom>2pt</PaddingBottom>
            </Style>
          </Textbox>
          <Textbox Name="MetadataTextbox">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>="Filters: " &amp; Parameters!FilterSummary.Value &amp; "  |  Generated on: " &amp; Parameters!GeneratedAt.Value &amp; " by " &amp; Parameters!GeneratedBy.Value</Value>
                    <Style>
                      <FontFamily>Segoe UI</FontFamily>
                      <FontSize>8pt</FontSize>
                      <Color>#64748B</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
              </Paragraph>
            </Paragraphs>
            <Top>0.6in</Top>
            <Left>0.2in</Left>
            <Height>0.2in</Height>
            <Width>6.1in</Width>
            <Style>
              <Border><Style>None</Style></Border>
              <PaddingLeft>2pt</PaddingLeft>
              <PaddingRight>2pt</PaddingRight>
              <PaddingTop>2pt</PaddingTop>
              <PaddingBottom>2pt</PaddingBottom>
            </Style>
          </Textbox>
          <Tablix Name="OccupancyTablix">
            <TablixBody>
              <TablixColumns>
                <TablixColumn>
                  <Width>1.6in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>0.8in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>0.8in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>0.9in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>1.3in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>0.8in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>1.0in</Width>
                </TablixColumn>
              </TablixColumns>
              <TablixRows>
                <TablixRow>
                  <Height>0.25in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderProperty">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Property / House</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderRoom">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Room No</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderType">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Room Type</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderRent">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Monthly Rent</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderTenant">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Tenant Name</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderRoomStatus">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Status</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderAgrStatus">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Agr. Status</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>
                <TablixRow>
                  <Height>0.22in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValProperty">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Fields!PropertyName.Value &amp; " / " &amp; Fields!HouseName.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValRoom">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Fields!RoomNo.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValType">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Fields!RoomType.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValRent">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Parameters!Currency.Value &amp; " " &amp; Format(Fields!MonthlyRent.Value, "N2")</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValTenant">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Iif(IsNothing(Fields!TenantName.Value) Or Fields!TenantName.Value = "", "-", Fields!TenantName.Value)</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValRoomStatus">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Fields!RoomStatus.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><Color>=Iif(Fields!RoomStatus.Value = "Available", "#10B981", Iif(Fields!RoomStatus.Value = "Occupied", "#3B82F6", "#F59E0B"))</Color><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValAgrStatus">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Iif(IsNothing(Fields!AgreementStatus.Value) Or Fields!AgreementStatus.Value = "", "-", Fields!AgreementStatus.Value)</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy>
              <TablixMembers>
                <TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember />
              </TablixMembers>
            </TablixColumnHierarchy>
            <TablixRowHierarchy>
              <TablixMembers>
                <TablixMember><KeepWithGroup>After</KeepWithGroup></TablixMember>
                <TablixMember><Group Name="Details" /></TablixMember>
              </TablixMembers>
            </TablixRowHierarchy>
            <DataSetName>OccupancyDataSet</DataSetName>
            <Top>0.95in</Top>
            <Left>0.2in</Left>
            <Height>0.47in</Height>
            <Width>7.2in</Width>
          </Tablix>
        </ReportItems>
        <Height>2.5in</Height>
      </Body>
      <Width>7.6in</Width>
      <Page>
        <PageFooter>
          <Height>0.4in</Height>
          <ReportItems>
            <Textbox Name="FooterLeft">
              <Paragraphs>
                <Paragraph><TextRuns><TextRun><Value>=Parameters!ApplicationName.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>8pt</FontSize><Color>#94A3B8</Color></Style></TextRun></TextRuns></Paragraph>
              </Paragraphs>
              <Top>0.1in</Top><Left>0.2in</Left><Height>0.2in</Height><Width>3.0in</Width>
            </Textbox>
            <Textbox Name="FooterRight">
              <Paragraphs>
                <Paragraph>
                  <TextRuns><TextRun><Value>="Page " &amp; Globals!PageNumber &amp; " of " &amp; Globals!TotalPages</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>8pt</FontSize><Color>#94A3B8</Color></Style></TextRun></TextRuns>
                  <Style><TextAlign>Right</TextAlign></Style>
                </Paragraph>
              </Paragraphs>
              <Top>0.1in</Top><Left>4.4in</Left><Height>0.2in</Height><Width>3.0in</Width>
