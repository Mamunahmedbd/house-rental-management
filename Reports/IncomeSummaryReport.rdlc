<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Textbox Name="TitleTextbox">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>=Parameters!ReportTitle.Value</Value>
                    <Style>
                      <FontFamily>Segoe UI</FontFamily>
                      <FontSize>16pt</FontSize>
                      <FontWeight>Bold</FontWeight>
                      <Color>#0F172A</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
              </Paragraph>
            </Paragraphs>
            <Top>0.2in</Top><Left>0.2in</Left><Height>0.35in</Height><Width>6.1in</Width>
            <Style>
              <Border><Style>None</Style></Border>
              <PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom>
            </Style>
          </Textbox>
          <Textbox Name="MetadataTextbox">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>="Filters: " &amp; Parameters!FilterSummary.Value &amp; "  |  Generated on: " &amp; Parameters!GeneratedAt.Value &amp; " by " &amp; Parameters!GeneratedBy.Value</Value>
                    <Style>
                      <FontFamily>Segoe UI</FontFamily>
                      <FontSize>8pt</FontSize>
                      <Color>#64748B</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
              </Paragraph>
            </Paragraphs>
            <Top>0.6in</Top><Left>0.2in</Left><Height>0.2in</Height><Width>6.1in</Width>
            <Style>
              <Border><Style>None</Style></Border>
              <PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom>
            </Style>
          </Textbox>
          <Tablix Name="IncomeTablix">
            <TablixBody>
              <TablixColumns>
                <TablixColumn>
                  <Width>1.2in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>1.1in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>1.1in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>0.8in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>1.0in</Width>
                </TablixColumn>
                <TablixColumn>
                  <Width>1.0in</Width>
                </TablixColumn>
              </TablixColumns>
              <TablixRows>
                <TablixRow>
                  <Height>0.25in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderPeriod">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Period</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderExpected">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Expected Rent</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderCollected">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Collected Rent</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderRate">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Coll. Rate</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderExpenses">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Expenses</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderNet">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Net Income</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>
                <TablixRow>
                  <Height>0.22in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValPeriod">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=MonthName(Fields!PeriodMonth.Value) &amp; " " &amp; Fields!PeriodYear.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValExpected">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Parameters!Currency.Value &amp; " " &amp; Format(Fields!ExpectedRent.Value, "N2")</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValCollected">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Parameters!Currency.Value &amp; " " &amp; Format(Fields!CollectedRent.Value, "N2")</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValRate">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Format(Fields!CollectionRate.Value, "0.0") &amp; "%"</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValExpenses">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Parameters!Currency.Value &amp; " " &amp; Format(Fields!TotalExpenses.Value, "N2")</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValNet">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Parameters!Currency.Value &amp; " " &amp; Format(Fields!NetIncome.Value, "N2")</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><Color>=Iif(Fields!NetIncome.Value &lt; 0, "#EF4444", "#10B981")</Color><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy>
              <TablixMembers>
                <TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember />
              </TablixMembers>
            </TablixColumnHierarchy>
            <TablixRowHierarchy>
              <TablixMembers>
                <TablixMember><KeepWithGroup>After</KeepWithGroup></TablixMember>
                <TablixMember><Group Name="Details" /></TablixMember>
              </TablixMembers>
            </TablixRowHierarchy>
            <DataSetName>IncomeDataSet</DataSetName>
            <Top>0.95in</Top><Left>0.2in</Left><Height>0.47in</Height><Width>6.2in</Width>
          </Tablix>
        </ReportItems>
        <Height>2.5in</Height>
      </Body>
      <Width>7.6in</Width>
      <Page>
        <PageFooter>
          <Height>0.4in</Height>
          <ReportItems>
            <Textbox Name="FooterLeft">
              <Paragraphs>
                <Paragraph><TextRuns><TextRun><Value>=Parameters!ApplicationName.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>8pt</FontSize><Color>#94A3B8</Color></Style></TextRun></TextRuns></Paragraph>
              </Paragraphs>
              <Top>0.1in</Top><Left>0.2in</Left><Height>0.2in</Height><Width>3.0in</Width>
            </Textbox>
            <Textbox Name="FooterRight">
              <Paragraphs>
                <Paragraph>
                  <TextRuns><TextRun><Value>="Page " &amp; Globals!PageNumber &amp; " of " &amp; Globals!TotalPages</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>8pt</FontSize><Color>#94A3B8</Color></Style></TextRun></TextRuns>
                  <Style><TextAlign>Right</TextAlign></Style>
                </Paragraph>
              </Paragraphs>
              <Top>0.1in</Top><Left>4.4in</Left><Height>0.2in</Height><Width>3.0in</Width>
            </Textbox>
          </ReportItems>
        </PageFooter>
        <PageHeight>11.69in</PageHeight><PageWidth>8.27in</PageWidth>
        <LeftMargin>0.3in</LeftMargin><RightMargin>0.3in</RightMargin>
        <TopMargin>0.4in</TopMargin><BottomMargin>0.4in</BottomMargin>
      </Page>
    </ReportSection>
  </ReportSections>
  <DataSources>
    <DataSource Name="ReportDataSource">
      <ConnectionProperties>
        <DataProvider>System.Data.DataSet</DataProvider>
        <ConnectString>/* Local Connection */</ConnectString>
      </ConnectionProperties>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="IncomeDataSet">
      <Query>
        <DataSourceName>ReportDataSource</DataSourceName>
        <CommandText>/* Local Query */</CommandText>
      </Query>
      <Fields>
        <Field Name="PeriodYear"><DataField>PeriodYear</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="PeriodMonth"><DataField>PeriodMonth</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="ExpectedRent"><DataField>ExpectedRent</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="CollectedRent"><DataField>CollectedRent</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="CollectionRate"><DataField>CollectionRate</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="TotalExpenses"><DataField>TotalExpenses</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="NetIncome"><DataField>NetIncome</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="ReportTitle"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank><Prompt>ReportTitle</Prompt></ReportParameter>
    <ReportParameter Name="FilterSummary"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank><Prompt>FilterSummary</Prompt></ReportParameter>
    <ReportParameter Name="GeneratedAt"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank><Prompt>GeneratedAt</Prompt></ReportParameter>
    <ReportParameter Name="GeneratedBy"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank><Prompt>GeneratedBy</Prompt></ReportParameter>
    <ReportParameter Name="Currency"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank><Prompt>Currency</Prompt></ReportParameter>
    <ReportParameter Name="ApplicationName"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank><Prompt>ApplicationName</Prompt></ReportParameter>
  </ReportParameters>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
</Report>
