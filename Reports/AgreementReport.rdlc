            </TablixColumnHierarchy>
            <TablixRowHierarchy>
              <TablixMembers>
                <TablixMember><KeepWithGroup>After</KeepWithGroup></TablixMember>
                <TablixMember><Group Name="Details" /></TablixMember>
              </TablixMembers>
            </TablixRowHierarchy>
            <DataSetName>AgreementDataSet</DataSetName>
            <Top>0.95in</Top><Left>0.2in</Left><Height>0.47in</Height><Width>7.2in</Width>
