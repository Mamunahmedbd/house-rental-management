                </TablixColumn>
              </TablixColumns>
              <TablixRows>
                <TablixRow>
                  <Height>0.25in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderAgr">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Agreement No</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderTenant">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Tenant Name</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderRoom">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Property / Room</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderStart">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Start Date</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderEnd">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>End Date</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderRent">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Rent</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="HeaderStatus">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>Status</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <BackgroundColor>#1E293B</BackgroundColor>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>4pt</PaddingTop><PaddingBottom>4pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>
                <TablixRow>
                  <Height>0.22in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValAgr">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Fields!AgreementNo.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValTenant">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Fields!TenantName.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValRoom">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Fields!PropertyName.Value &amp; " / " &amp; Fields!RoomNo.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValStart">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Format(Fields!StartDate.Value, "yyyy-MM-dd")</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValEnd">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Format(Fields!EndDate.Value, "yyyy-MM-dd")</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValRent">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Parameters!Currency.Value &amp; " " &amp; Format(Fields!MonthlyRent.Value, "N2")</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <TextAlign>Right</TextAlign>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ValStatus">
                          <Paragraphs>
                            <Paragraph><TextRuns><TextRun><Value>=Fields!AgreementStatus.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><Color>=Iif(Fields!AgreementStatus.Value = "Active", "#10B981", Iif(Fields!AgreementStatus.Value = "Expired", "#EF4444", "#64748B"))</Color><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>5pt</PaddingLeft><PaddingRight>5pt</PaddingRight><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom>
                            <BackgroundColor>=Iif(RowNumber(Nothing) Mod 2 = 0, "#F8FAFC", "#FFFFFF")</BackgroundColor>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy>
              <TablixMembers>
                <TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember />
